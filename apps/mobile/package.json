{
  "name": "@vibevault/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo run:android",
    "android:release": "expo run:android --variant release --no-install",
    "build:android:preview": "eas build --profile preview --platform android",
    "build:android:production": "eas build --profile production --platform android",
    "build:android:standalone": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-android-standalone.ps1",
    "build:android:rebundle": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/rebundle-release-apk.ps1",
    "build:android:preview:local": "eas build --profile preview --platform android --local",
    "build:android:production:local": "eas build --profile production --platform android --local",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "build": "expo export --platform ios --output-dir dist"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.1",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@hookform/resolvers": "^5.0.1",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.74.4",
    "@vibevault/config": "workspace:*",
    "@vibevault/types": "workspace:*",
    "@vibevault/ui": "workspace:*",
    "@vibevault/utils": "workspace:*",
    "expo": "~54.0.35",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "nativewind": "^4.0.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.56.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^3.2.0",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-track-player": "^4.1.2",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "~0.5.1",
    "tailwindcss": "^3.4.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-track-player"
        ]
      }
    }
  }
}
