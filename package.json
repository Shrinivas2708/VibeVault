{
  "name": "onetune",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "website"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "website:dev": "bun run --filter @onetune/website dev",
    "website:build": "bun run --filter @onetune/website build",
    "website:preview": "bun run --filter @onetune/website preview",
    "website:serve": "bun run website:build && npx serve website/dist",
    "website:sync-apk": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/sync-website-apk.ps1",
    "postinstall": "node scripts/patch-track-player-turbo.mjs"
  },
  "devDependencies": {
    "patch-package": "^8.0.1",
    "turbo": "^2.10.2",
    "typescript": "~5.9.3"
  },
  "packageManager": "bun@1.3.14"
}
